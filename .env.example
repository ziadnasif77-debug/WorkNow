# ─────────────────────────────────────────────────────────────────────────────
# WorkFix — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it's in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (Mobile / Expo) ──────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
EXPO_PUBLIC_PROJECT_ID=your_project_id
EXPO_PUBLIC_USE_EMULATOR=false

# ── Firebase (Cloud Functions) ────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your_project_id

# ── Tap Payments (unified gateway: MENA + Scandinavia) ────────────────────────
# Get from tappayments.com → Developers → API Keys
# Supports: SAR, AED, KWD, QAR, BHD, OMR, EGP, NOK, SEK
# Supports: Visa, Mastercard, Apple Pay, STC Pay, Mada, Vipps, Swish
# WARNING: Never expose SECRET key in mobile apps
TAP_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAP_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Unifonic (SMS / OTP) ──────────────────────────────────────────────────────
# For MENA numbers — Norway/Sweden use Firebase Auth phone directly
UNIFONIC_APP_SID=your_app_sid
UNIFONIC_SENDER_ID=WorkFix

# ── EAS (Expo Application Services) ──────────────────────────────────────────
EXPO_TOKEN=your_expo_token_here

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry — get from sentry.io → Settings → Projects → DSN
EXPO_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/yyyy
# Environment: 'production' | 'development'
EXPO_PUBLIC_ENV=development

# ── Tap Payments Webhook ──────────────────────────────────────────────────────
TAP_WEBHOOK_SECRET=your_tap_webhook_secret

# ── Supported Markets ─────────────────────────────────────────────────────────
# MENA:        SA (SAR), AE (AED), KW (KWD), QA (QAR), BH (BHD), OM (OMR), EG (EGP)
# Scandinavia: NO (NOK) — Vipps + Card, SE (SEK) — Swish + Card
#
# Payment method availability per country:
#   SA  → card, apple_pay, stc_pay, mada, cash
#   AE  → card, apple_pay, cash
#   NO  → card, apple_pay, vipps
#   SE  → card, apple_pay, swish

# ── Feature Flags (Firebase Remote Config) ───────────────────────────────────
# subscriptions_enabled=false
# boost_enabled=false
# disputes_enabled=false
# cash_payment_enabled=true
# agency_model_enabled=false
# norway_market_enabled=true
# sweden_market_enabled=true
