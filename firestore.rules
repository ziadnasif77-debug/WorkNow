rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── دوال مساعدة ────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isAuth() && role() in ['admin', 'superadmin'];
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isProvider() {
      return isAuth() && role() == 'provider';
    }
    function isCustomer() {
      return isAuth() && role() == 'customer';
    }
    function isOrderParty(orderId) {
      let order = get(/databases/$(database)/documents/orders/$(orderId)).data;
      return isAuth() &&
        (request.auth.uid == order.customerId ||
         request.auth.uid == order.providerId);
    }

    // ── users ───────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && isOwner(userId);
      allow update: if isOwner(userId) &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('isVerified' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read, update: if isOwner(userId);
        allow create: if isAdmin() || request.auth.uid == userId;
        allow delete: if isOwner(userId);
      }
    }

    // ── providerProfiles ────────────────────────────────────────────────────────
    match /providerProfiles/{providerId} {
      allow read: if isAuth();
      allow create: if isProvider() && isOwner(providerId)
        && request.resource.data.keys().hasOnly([
             'name', 'photoUrl', 'bio', 'createdAt'
           ])
        && !('kycStatus'    in request.resource.data)
        && !('avgRating'    in request.resource.data)
        && !('totalReviews' in request.resource.data)
        && !('isVerified'   in request.resource.data)
        && !('role'         in request.resource.data);
      allow update: if (isOwner(providerId) &&
        !('kycStatus'    in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('avgRating'    in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('totalReviews' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('isVerified'   in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ── orders ──────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.customerId == request.auth.uid) ||
        (isAuth() && resource.data.providerId == request.auth.uid);
      allow create: if isCustomer() &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.status == 'pending';
      // All state transitions go through Cloud Functions (Admin SDK bypasses rules).
      // Direct client writes are blocked to prevent state-machine bypass.
      allow update: if isAdmin();
      allow delete: if false;

      match /quotes/{quoteId} {
        allow read: if isOrderParty(orderId) || isAdmin();
        allow create: if isProvider() &&
          request.resource.data.providerId == request.auth.uid;
        // Quote accept/reject must go through acceptQuote Cloud Function.
        allow update: if isAdmin();
        allow delete: if false;
      }
    }

    // ── conversations & messages ─────────────────────────────────────────────────
    match /conversations/{convId} {
      // TTL-based typing: clients write typingExpiresAt.{uid} = timestamp
      // (replaces the old boolean typingStatus — no delete write needed)
      allow read, update: if isAdmin() || (isAuth() &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.providerId == request.auth.uid));
      allow create: if isAuth() && (
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.providerId != request.auth.uid &&
        exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId)) &&
        get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.customerId
          == request.auth.uid &&
        get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.providerId
          == request.resource.data.providerId
      ) || isAdmin();
      allow delete: if false;

      match /messages/{msgId} {
        // Only the two parties in the parent conversation may read messages.
        // "isAuth()" alone would allow any logged-in user to read any message.
        allow read: if isAdmin() || (isAuth() && (
          resource.data.senderId   == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.customerId  == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.providerId  == request.auth.uid
        ));
        allow create: if isAuth() && (
          request.resource.data.senderId == request.auth.uid &&
          (get(/databases/$(database)/documents/conversations/$(convId)).data.customerId == request.auth.uid ||
           get(/databases/$(database)/documents/conversations/$(convId)).data.providerId == request.auth.uid)
        );
        allow update: if isAuth() &&
          resource.data.senderId != request.auth.uid &&
          (get(/databases/$(database)/documents/conversations/$(convId)).data.customerId == request.auth.uid ||
           get(/databases/$(database)/documents/conversations/$(convId)).data.providerId == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead','readAt']) &&
          request.resource.data.isRead == true;
        allow delete: if false;
      }
    }

    // ── payments ─────────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAdmin() ||
        (isAuth() && (resource.data.customerId == request.auth.uid ||
                      resource.data.providerId == request.auth.uid));
      allow write: if false;
    }

    // ── reviews ──────────────────────────────────────────────────────────────────
    // All writes go through submitReview Cloud Function (Admin SDK only).
    // Client direct-write is completely denied.
    match /reviews/{reviewId} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }

    // ── disputes ─────────────────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read: if isAdmin() || isOrderParty(resource.data.orderId);
      allow create: if isAuth() &&
        request.resource.data.initiatorId == request.auth.uid &&
        isOrderParty(request.resource.data.orderId) &&
        get(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
          .data.status in ['completed', 'in_progress'];
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── categories & services ────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /services/{serviceId} {
      // Active services are visible to any authenticated user (marketplace browsing).
      // Inactive (draft/paused) services are visible only to the owning provider and admins.
      allow read: if isAuth() && (
        resource.data.isActive == true ||
        resource.data.providerId == request.auth.uid ||
        isAdmin()
      );
      // Create: caller must be the providerId they set; block system-controlled fields
      allow create: if isProvider()
        && request.resource.data.providerId == request.auth.uid
        && !('avgRating'   in request.resource.data)
        && !('totalOrders' in request.resource.data);
      // Update: ownership verified on EXISTING doc; providerId must not change;
      // only safe presentation fields may be touched.
      allow update: if isProvider()
        && resource.data.providerId == request.auth.uid
        && request.resource.data.providerId == resource.data.providerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
             'title', 'description', 'price', 'categoryId', 'imageUrls',
             'isActive', 'duration', 'tags', 'updatedAt'
           ]);
      allow delete: if isAdmin() ||
        (isProvider() && resource.data.providerId == request.auth.uid);
    }

    // ── subscriptions ────────────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAdmin() ||
        (isProvider() && resource.data.providerId == request.auth.uid);
      allow write: if false;
    }

    // ── payouts ──────────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isAdmin() ||
        (isProvider() && resource.data.providerId == request.auth.uid);
      allow write: if false;
    }

    // ── adminTasks — written by Cloud Functions only (Admin SDK) ─────────────────
    match /adminTasks/{taskId} {
      allow read, write: if false;
    }

    // ── scheduledReleases ─────────────────────────────────────────────────────────
    match /scheduledReleases/{docId} {
      allow read, write: if false; // Functions only
    }

    // ── invoices — billing records ────────────────────────────────────────────────
    // Customer or provider of the order can read their own invoices
    // Write only via CF admin SDK
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (isAuth() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      ));
      allow write: if false;
    }

    // ── invoiceCounters — sequential invoice numbering ────────────────────────────
    match /invoiceCounters/{counterId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── dataExports — GDPR data portability ───────────────────────────────────────
    match /dataExports/{exportId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ── deletionRequests — GDPR right to erasure ──────────────────────────────────
    match /deletionRequests/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── kycSubmissions — sensitive KYC documents ─────────────────────────────────
    // kycDocumentUrls are stored here, NOT in providerProfiles.
    // Providers can read their own submission (status + documentUrls are theirs).
    // Only admins can read other providers' submissions.
    // All writes go through Cloud Functions (Admin SDK) — no direct client writes.
    match /kycSubmissions/{userId} {
      allow read:  if isAdmin() || (isAuth() && request.auth.uid == userId);
      allow write: if false;  // Cloud Functions (Admin SDK) only
    }

    // ── jobs — job postings created by providers ──────────────────────────────────
    // Any authenticated user can browse jobs.
    // All writes (create, update, close) go through Cloud Functions only.
    match /jobs/{jobId} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // ── jobApplications — applications submitted by users ─────────────────────────
    // Applicant sees their own applications; provider sees applications for their jobs.
    // All writes go through Cloud Functions only.
    match /jobApplications/{appId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.applicantId == request.auth.uid) ||
        (isAuth() && resource.data.providerId  == request.auth.uid);
      allow write: if false;
    }

    // ── System collections — Admin SDK only, zero client access ──────────────────
    // _auditLogs: compliance audit trail — no direct client read (query via CF)
    match /_auditLogs/{docId} {
      allow read, write: if false;
    }

    match /_rateLimits/{docId} {
      allow read, write: if false;
    }

    match /_taskQueue/{docId} {
      allow read, write: if false;
    }

    // ── _deadTasks — failed jobs dead-letter queue ────────────────────────────────
    match /_deadTasks/{docId} {
      allow read, write: if false;
    }

    // ── _idempotencyKeys — review/payment dedup store ─────────────────────────────
    match /_idempotencyKeys/{docId} {
      allow read, write: if false;
    }

    // ── _webhookEvents — replay protection store ──────────────────────────────────
    match /_webhookEvents/{eventId} {
      allow read, write: if false;
    }

    // ── _payoutLocks — per-provider payout mutex (admin SDK only) ─────────────────
    match /_payoutLocks/{uid} {
      allow read, write: if false;
    }

    // ── fraudAlerts — admin read only, written by triggers ────────────────────────
    match /fraudAlerts/{alertId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

  }
}