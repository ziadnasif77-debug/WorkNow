rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── دوال مساعدة ────────────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function role() {
      return request.auth.token.role;
    }
    function isAdmin() {
      return isAuth() && role() in ['admin', 'superadmin'];
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function isProvider() {
      return isAuth() && role() == 'provider';
    }
    function isCustomer() {
      return isAuth() && role() == 'customer';
    }
    function isOrderParty(orderId) {
      let order = get(/databases/$(database)/documents/orders/$(orderId)).data;
      return isAuth() &&
        (request.auth.uid == order.customerId ||
         request.auth.uid == order.providerId);
    }

    // ── users ───────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuth() && isOwner(userId);
      allow update: if isOwner(userId) &&
        !('role' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('isVerified' in request.resource.data.diff(resource.data).affectedKeys());
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read, update: if isOwner(userId);
        allow create: if isAdmin() || request.auth.uid == userId;
        allow delete: if isOwner(userId);
      }
    }

    // ── providerProfiles ────────────────────────────────────────────────────────
    match /providerProfiles/{providerId} {
      allow read: if isAuth();
      allow create: if isProvider() && isOwner(providerId)
        && request.resource.data.keys().hasOnly([
             'name', 'photoUrl', 'bio', 'createdAt'
           ])
        && !('kycStatus'    in request.resource.data)
        && !('avgRating'    in request.resource.data)
        && !('totalReviews' in request.resource.data)
        && !('isVerified'   in request.resource.data)
        && !('role'         in request.resource.data);
      allow update: if (isOwner(providerId) &&
        !('kycStatus'    in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('avgRating'    in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('totalReviews' in request.resource.data.diff(resource.data).affectedKeys()) &&
        !('isVerified'   in request.resource.data.diff(resource.data).affectedKeys()))
        || isAdmin();
      allow delete: if isAdmin();
    }

    // ── orders ──────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow read: if isAdmin() ||
        (isAuth() && resource.data.customerId == request.auth.uid) ||
        (isAuth() && resource.data.providerId == request.auth.uid);
      allow create: if isCustomer() &&
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin() ||
        (isAuth() &&
          resource.data.providerId == request.auth.uid &&
          request.resource.data.status in ['confirmed','in_progress','completed'] &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt'])) ||
        (isAuth() &&
          resource.data.customerId == request.auth.uid &&
          request.resource.data.status in ['closed','cancelled','disputed'] &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt']));
      allow delete: if false;

      match /quotes/{quoteId} {
        allow read: if isOrderParty(orderId) || isAdmin();
        allow create: if isProvider() &&
          request.resource.data.providerId == request.auth.uid;
        allow update: if isAdmin() ||
          (get(/databases/$(database)/documents/orders/$(orderId)).data.customerId
             == request.auth.uid &&
           request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'updatedAt']) &&
           request.resource.data.status in ['accepted', 'rejected']);
        allow delete: if false;
      }
    }

    // ── conversations & messages ─────────────────────────────────────────────────
    match /conversations/{convId} {
      // TTL-based typing: clients write typingExpiresAt.{uid} = timestamp
      // (replaces the old boolean typingStatus — no delete write needed)
      allow read, update: if isAdmin() || (isAuth() &&
        (resource.data.customerId == request.auth.uid ||
         resource.data.providerId == request.auth.uid));
      // FIX [MEDIUM]: Require that the order referenced in the conversation
      // actually exists and that the creator is a party to that order.
      // Prevents arbitrary conversation creation between unrelated users.
      allow create: if isAuth() && (
        request.resource.data.customerId == request.auth.uid &&
        request.resource.data.providerId != request.auth.uid &&
        exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId)) &&
        get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.customerId
          == request.auth.uid &&
        get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.providerId
          == request.resource.data.providerId
      ) || isAdmin();
      allow delete: if false;

      match /messages/{msgId} {
        // Only the two parties in the parent conversation may read messages.
        // "isAuth()" alone would allow any logged-in user to read any message.
        allow read: if isAdmin() || (isAuth() && (
          resource.data.senderId   == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.customerId  == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(convId)).data.providerId  == request.auth.uid
        ));
        allow create: if isAuth() && (
          request.resource.data.senderId == request.auth.uid &&
          (get(/databases/$(database)/documents/conversations/$(convId)).data.customerId == request.auth.uid ||
           get(/databases/$(database)/documents/conversations/$(convId)).data.providerId == request.auth.uid)
        );
        allow update: if isAuth() &&
          resource.data.senderId != request.auth.uid &&
          (get(/databases/$(database)/documents/conversations/$(convId)).data.customerId == request.auth.uid ||
           get(/databases/$(database)/documents/conversations/$(convId)).data.providerId == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['isRead','readAt']) &&
          request.resource.data.isRead == true;
        allow delete: if false;
      }
    }

    // ── payments ─────────────────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAdmin() ||
        (isAuth() && (resource.data.customerId == request.auth.uid ||
                      resource.data.providerId == request.auth.uid));
      allow write: if false;
    }

    // ── reviews ──────────────────────────────────────────────────────────────────
    // All writes go through submitReview Cloud Function (Admin SDK only).
    // Client direct-write is completely denied.
    match /reviews/{reviewId} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }

    // ── disputes ─────────────────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read: if isAdmin() || isOrderParty(resource.data.orderId);
      // FIX [MEDIUM]: Require that the dispute is tied to a real order the
      // initiator is party to, and that the order is in a disputable state.
      allow create: if isAuth() &&
        request.resource.data.initiatorId == request.auth.uid &&
        isOrderParty(request.resource.data.orderId) &&
        get(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
          .data.status in ['completed', 'in_progress'];
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ── categories & services ────────────────────────────────────────────────────
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /services/{serviceId} {
      allow read: if true;
      allow create, update: if isProvider() &&
        request.resource.data.providerId == request.auth.uid;
      allow delete: if isAdmin() ||
        (isProvider() && resource.data.providerId == request.auth.uid);
    }

    // ── subscriptions ────────────────────────────────────────────────────────────
    match /subscriptions/{subId} {
      allow read: if isAdmin() ||
        (isProvider() && resource.data.providerId == request.auth.uid);
      allow write: if false;
    }

    // ── payouts ──────────────────────────────────────────────────────────────────
    match /payouts/{payoutId} {
      allow read: if isAdmin() ||
        (isProvider() && resource.data.providerId == request.auth.uid);
      allow write: if false;
    }

    // ── adminTasks ───────────────────────────────────────────────────────────────
    match /adminTasks/{taskId} {
      allow read, write: if isAdmin();
    }

    // ── scheduledReleases ─────────────────────────────────────────────────────────
    match /scheduledReleases/{docId} {
      allow read, write: if false; // Functions only
    }

    // ── invoices — billing records ────────────────────────────────────────────────
    // Customer or provider of the order can read their own invoices
    // Write only via CF admin SDK
    match /invoices/{invoiceId} {
      allow read: if isAdmin() || (isAuth() && (
        resource.data.customerId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      ));
      allow write: if false;
    }

    // ── invoiceCounters — sequential invoice numbering ────────────────────────────
    match /invoiceCounters/{counterId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── dataExports — GDPR data portability ───────────────────────────────────────
    match /dataExports/{exportId} {
      allow read: if isAuth() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ── deletionRequests — GDPR right to erasure ──────────────────────────────────
    match /deletionRequests/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ── System collections — Admin SDK only, no client access ─────────────────────
    match /_auditLogs/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /_rateLimits/{docId} {
      allow read, write: if false;
    }

    match /_taskQueue/{docId} {
      allow read, write: if false;
    }

    // ── fraudAlerts — admin read only, written by triggers ────────────────────────
    match /fraudAlerts/{alertId} {
      allow read:  if isAdmin();
      allow write: if false;
    }

  }
}