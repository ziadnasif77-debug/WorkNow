{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": [
      "jest"
    ],
    "paths": {
      "@workfix/types": [
        "../../packages/types/src/index.ts"
      ],
      "@workfix/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@workfix/config": [
        "../../packages/config/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts",
    "nativewind-env.d.ts"
  ]
}