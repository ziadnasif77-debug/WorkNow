# ─────────────────────────────────────────────────────────────────────────────
# WorkFix Mobile — Environment Variables
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in values from: Firebase Console → Project Settings → Your apps
# 3. Restart Expo:    expo start --clear
#
# NEVER commit .env — it contains secrets. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase Web SDK config ────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → General → Your apps → Web app
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Optional — only needed if you use Google Analytics in Firebase
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Emulator (local development only) ─────────────────────────────────────────
# Set to true to connect to local Firebase emulators (port defaults: auth=9099,
# firestore=8080, functions=5001, storage=9199).
EXPO_PUBLIC_USE_EMULATOR=false

# ── Monitoring ─────────────────────────────────────────────────────────────────
# Sentry DSN — get from: sentry.io → Your project → Settings → Client Keys (DSN)
# Leave empty to disable Sentry in development.
EXPO_PUBLIC_SENTRY_DSN=
# 'production' enables Sentry + Crashlytics; anything else = dev mode (console only)
EXPO_PUBLIC_ENV=development
