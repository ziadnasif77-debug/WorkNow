{
  "name": "@workfix/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:dev": "eas build --profile development --platform all",
    "build:prod": "eas build --profile production --platform all",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "test": "jest --watchAll=false --passWithNoTests",
    "build": "eas build --platform all --profile production",
    "start:tunnel": "expo start --tunnel",
    "prebuild": "expo prebuild --clean",
    "build:preview": "eas build --profile preview --platform all",
    "submit": "eas submit --profile production --platform all",
    "update": "eas update --auto",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^4.6.0",
    "@react-native-async-storage/async-storage": "^2.0.0",
    "@react-native-community/datetimepicker": "^8.2.0",
    "@react-native-community/netinfo": "^11.3.2",
    "@react-native-firebase/analytics": "^20.0.0",
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-firebase/crashlytics": "^20.0.0",
    "@sentry/react-native": "^7.2.0",
    "@workfix/config": "workspace:*",
    "@workfix/types": "workspace:*",
    "@workfix/utils": "workspace:*",
    "date-fns": "^3.6.0",
    "expo": "~54.0.0",
    "expo-dev-client": "^4.0.29",
    "expo-document-picker": "~12.0.1",
    "expo-font": "~13.0.2",
    "expo-image-picker": "~16.0.3",
    "expo-location": "~18.0.4",
    "expo-notifications": "~0.29.11",
    "expo-router": "~3.5.23",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.0.1",
    "expo-store-review": "~7.0.2",
    "expo-updates": "~0.26.11",
    "firebase": "^10.12.0",
    "i18next": "^23.11.0",
    "intl-pluralrules": "^2.0.1",
    "nativewind": "^4.2.3",
    "react": "18.2.0",
    "react-i18next": "^14.1.0",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-mmkv": "^2.12.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~3.35.0",
    "react-native-webview": "^13.8.0",
    "react-native-worklets-core": "^1.3.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.2.45",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.0.0",
    "jest": "^29.0.0",
    "jest-expo": "~54.0.17",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
