{
  "name": "@workfix/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "set EXPO_PACKAGER_HOSTNAME=192.168.0.8 && npx expo start --lan",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev": "eas build --profile development --platform all",
    "build:prod": "eas build --profile production --platform all",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "test": "jest --watchAll=false --passWithNoTests",
    "build": "eas build --platform all --profile production",
    "start:tunnel": "expo start --tunnel",
    "prebuild": "expo prebuild --clean",
    "build:preview": "eas build --profile preview --platform all",
    "submit": "eas submit --profile production --platform all",
    "update": "eas update --auto",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^4.6.0",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/datetimepicker": "^8.0.1",
    "@react-native-community/netinfo": "^11.3.1",
    "@react-native-firebase/analytics": "^20.0.0",
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-firebase/crashlytics": "^20.0.0",
    "@sentry/react-native": "^5.24.3",
    "@workfix/config": "workspace:*",
    "@workfix/types": "workspace:*",
    "@workfix/utils": "workspace:*",
    "date-fns": "^3.6.0",
    "expo": "~54.0.33",
    "expo-font": "~12.0.0",
    "expo-image-picker": "~15.1.0",
    "expo-location": "~17.0.0",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-updates": "~0.25.0",
    "firebase": "^10.12.0",
    "i18next": "^23.11.0",
    "nativewind": "^4.2.3",
    "react": "18.2.0",
    "react-i18next": "^14.1.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.2",
    "react-native-mmkv": "^2.12.0",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.0",
    "react-native-webview": "^13.8.6",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/react": "~18.2.0",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.0.0",
    "jest": "^29.0.0",
    "jest-expo": "~51.0.0",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3"
  }
}
