{
  "name": "@workfix/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev": "eas build --profile development --platform all",
    "build:prod": "eas build --profile production --platform all",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "test": "jest --watchAll=false --passWithNoTests",
    "build": "eas build --platform all --profile production",
    "start:tunnel": "expo start --tunnel",
    "prebuild": "expo prebuild --clean",
    "build:preview": "eas build --profile preview --platform all",
    "submit": "eas submit --profile production --platform all",
    "update": "eas update --auto",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "dependencies": {
    "@workfix/types": "workspace:*",
    "@workfix/utils": "workspace:*",
    "@workfix/config": "workspace:*",
    "expo": "~54.0.33",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~2.2.3",
    "expo-location": "~19.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-notifications": "~0.32.16",
    "expo-secure-store": "~14.2.4",
    "expo-font": "~13.3.2",
    "expo-updates": "~0.28.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.16.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "firebase": "^10.12.0",
    "nativewind": "^4.2.3",
    "tailwindcss": "^3.4.0",
    "zustand": "^4.5.0",
    "i18next": "^23.11.0",
    "react-i18next": "^14.1.0",
    "@gorhom/bottom-sheet": "^4.6.0",
    "react-native-mmkv": "^2.12.0",
    "date-fns": "^3.6.0",
    "react-native-webview": "^13.8.0",
    "@react-native-community/datetimepicker": "^8.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "^5.20.0",
    "@react-native-firebase/analytics": "^20.0.0",
    "@react-native-firebase/crashlytics": "^20.0.0",
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-community/netinfo": "^11.3.0"
  },
  "devDependencies": {
    "typescript": "~5.9.2",
    "@types/react": "~19.1.0",
    "@babel/core": "^7.24.0",
    "jest": "^29.0.0",
    "jest-expo": "~54.0.17",
    "@testing-library/react-native": "^12.5.0",
    "@testing-library/jest-native": "^5.4.3",
    "react-test-renderer": "19.1.0",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.0.0"
  }
}
