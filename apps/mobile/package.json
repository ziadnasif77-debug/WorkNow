{
  "name": "@workfix/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --lan --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev": "eas build --profile development --platform all",
    "build:prod": "eas build --profile production --platform all",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "test": "jest --watchAll=false --passWithNoTests",
    "build": "eas build --platform all --profile production",
    "start:tunnel": "expo start --tunnel",
    "prebuild": "expo prebuild --clean",
    "build:preview": "eas build --profile preview --platform all",
    "submit": "eas submit --profile production --platform all",
    "update": "eas update --auto",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --watchAll=false",
    "test:ci": "jest --ci --coverage --watchAll=false"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^4.6.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-firebase/analytics": "^20.0.0",
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-firebase/crashlytics": "^20.0.0",
    "@sentry/react-native": "^7.2.0",
    "@workfix/config": "workspace:*",
    "@workfix/types": "workspace:*",
    "@workfix/utils": "workspace:*",
    "date-fns": "^3.6.0",
    "expo": "~55.0.12",
    "expo-document-picker": "~13.0.3",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~55.0.13",
    "expo-updates": "~29.0.16",
    "firebase": "^10.12.0",
    "i18next": "^23.11.0",
    "intl-pluralrules": "^2.0.1",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-i18next": "^14.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^2.12.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "^13.15.0",
    "react-native-worklets-core": "^1.6.3",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.17",
    "@types/react-test-renderer": "^18.0.0",
    "babel-jest": "^29.0.0",
    "jest": "^29.0.0",
    "jest-expo": "~54.0.17",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}