rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isAuth()  { return request.auth != null; }
    function uid()     { return request.auth.uid; }
    function role()    { return request.auth.token.role; }
    function isAdmin() { return role() in ['admin', 'superadmin']; }
    function maxSizeMB(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }
    // Strict content-type whitelist — blocks polyglot files
    function isImage() {
      return request.resource.contentType in ['image/jpeg', 'image/png', 'image/webp'];
    }
    function isDocument() {
      return request.resource.contentType in [
        'application/pdf',
        'image/jpeg',
        'image/png',
        'image/webp'
      ];
    }

    // ── avatars/{userId}/* ────────────────────────────────────────────────────
    match /avatars/{userId}/{fileName} {
      allow read:   if true;                             // public CDN
      allow write:  if isAuth()
        && uid() == userId
        && isImage()
        && maxSizeMB(5);
      allow delete: if isAuth() && (uid() == userId || isAdmin());
    }

    // ── kyc/{userId}/* ────────────────────────────────────────────────────────
    match /kyc/{userId}/{fileName} {
      allow read:   if isAuth() && (uid() == userId || isAdmin());
      allow write:  if isAuth()
        && uid() == userId
        && isDocument()
        && maxSizeMB(10);
      allow delete: if isAdmin();
    }

    // ── orders/{orderId}/attachments/* ────────────────────────────────────────
    // FIX [HIGH]: Previously allowed any authenticated user to write.
    // Now enforces that only the two order parties (customer + provider) can
    // read or write attachments — verified via Firestore order document.
    match /orders/{orderId}/attachments/{fileName} {
      function isOrderParty() {
        let order = firestore.get(
          /databases/(default)/documents/orders/$(orderId)
        ).data;
        return uid() == order.customerId || uid() == order.providerId;
      }
      allow read:   if isAuth() && (isAdmin() || isOrderParty());
      allow write:  if isAuth()
        && isOrderParty()
        && isDocument()
        && maxSizeMB(10);
      allow delete: if isAdmin() || (isAuth() && isOrderParty());
    }

    // ── messages/{convId}/* ───────────────────────────────────────────────────
    // Only the two conversation parties may read or upload media files.
    match /messages/{convId}/{fileName} {
      function isConvMember() {
        let conv = firestore.get(
          /databases/(default)/documents/conversations/$(convId)
        ).data;
        return uid() == conv.customerId || uid() == conv.providerId;
      }
      allow read:   if isAuth() && (isAdmin() || isConvMember());
      allow write:  if isAuth()
        && isConvMember()
        && isDocument()
        && maxSizeMB(20);
      allow delete: if isAdmin();
    }

    // ── portfolio/{providerId}/* ──────────────────────────────────────────────
    match /portfolio/{providerId}/{fileName} {
      allow read:   if true;                             // public marketplace
      allow write:  if isAuth()
        && uid() == providerId
        && isImage()
        && maxSizeMB(10);
      allow delete: if isAuth() && (uid() == providerId || isAdmin());
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
