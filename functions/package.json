{
  "name": "@workfix/functions",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration --runInBand",
    "test:rules": "firebase emulators:exec --only firestore 'jest --testPathPattern=emulator'",
    "test:coverage": "jest --coverage --testPathPattern=unit",
    "test:all": "jest --runInBand",
    "deploy:dev": "firebase deploy --only functions --project dev",
    "deploy:prod": "firebase deploy --only functions --project prod",
    "clean": "rm -rf dist",
    "test:unit": "jest --testPathPattern=unit --coverage"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "@workfix/config": "workspace:*",
    "@workfix/types": "workspace:*",
    "@workfix/utils": "workspace:*",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "ngeohash": "^0.6.3",
    "pdf-lib": "^1.17.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/ngeohash": "^0.6.6",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
