{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "commonjs",
    "lib": [
      "ES2020"
    ],
    "target": "ES2020",
    "moduleResolution": "node",
    "strict": true,
    "noUnusedLocals": false,
    "paths": {
      "@workfix/types": [
        "../packages/types/src/index.ts"
      ],
      "@workfix/utils": [
        "../packages/utils/src/index.ts"
      ],
      "@workfix/config": [
        "../packages/config/src/index.ts"
      ]
    },
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
